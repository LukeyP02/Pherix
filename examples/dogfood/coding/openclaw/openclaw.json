{
  "mcpServers": {
    "pherix": {
      "command": "python",
      "args": [
        "-m",
        "pherix.frontends.proxy",
        "examples.dogfood.coding.openclaw.gateway_config"
      ],
      "env": {
        "PYTHONPATH": "/ABSOLUTE/PATH/TO/Pherix",
        "PHERIX_OPENCLAW_DB": "/ABSOLUTE/PATH/TO/openclaw-tasks.db",
        "PHERIX_OPENCLAW_AUDIT": "/ABSOLUTE/PATH/TO/openclaw-audit.db"
      }
    }
  }
}
